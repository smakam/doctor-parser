# Doctor Nameboard Extractor — Backend Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Supabase (PostgreSQL + Auth)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# No JWT secret needed — public key fetched automatically from Supabase JWKS endpoint

# Google Cloud Vision API
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# ImageKit
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-imagekit-id

# Mappls (MapmyIndia) — optional, geocoding is skipped if not set
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=

# PII Encryption
PII_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# App
SECRET_KEY=your-app-secret-key
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
